# Development (default: `bun run dev` starts signaling + Next.js)
# Signaling server URL — only needed when signaling runs on a separate port/host
NEXT_PUBLIC_SIGNALING_URL=http://localhost:3001
SIGNALING_PORT=3001

# Production integrated server (`bun run start`): leave NEXT_PUBLIC_SIGNALING_URL unset
# so the client uses same-origin signaling at /api/socketio

# Production split deployment: point to your external signaling server
# NEXT_PUBLIC_SIGNALING_URL=https://your-signaling-server.example.com